# Print variable is even or odd
import java.util.*;
class Main {
    public static void main(String[] args) {
        int a=123;
        for(int i=0;i<a;i++){
            if((a&1)== 0){
                System.out.println("even");
            }else{
                System.out.println("odd");
            }
        }
    }
}

# Convertion of numeric value  into binary format
import java.lang.*;
class DAY1{
    public static void main (String [] args){
        Scanner obj=new Scanner(System.in);
        int n=obj.nextInt();
        String Binary=" ";
        while(n>0){
            int rem =n%2;
            Binary=rem+Binary;
            n=n/2;
        }
        System.out.println(Binary);
    }
}
